<launch>
    <arg name="simulation_data" default="$(find stonefish_description)"/> <!-- path to the data directory -->
    <arg name="scenario_description" default="$(find stonefish_description)/scenarios/bluerov2_tank.scn"/> <!-- path to the scenario description -->
    <arg name="simulation_rate" default="500"/> <!-- number of simulation steps per second -->
    <arg name="graphics_resolution" default="1200 800"/> <!-- resolution of the simulation window -->
    <arg name="graphics_quality" default="low"/> <!-- low, medium or high -->

    <node name="stonefish_simulator" pkg="stonefish_ros" type="parsed_simulator" args="$(arg simulation_data) $(arg scenario_description) $(arg simulation_rate) $(arg graphics_resolution) $(arg graphics_quality)" output="screen">
        <!-- Disable compressed_depth image transport to avoid errors with RGB cameras -->
        <env name="IMAGE_TRANSPORT_DISABLED_TRANSPORTS" value="compressed_depth"/>
    </node>
</launch>
