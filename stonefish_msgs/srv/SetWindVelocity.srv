# SetWindVelocity.srv
# Request to set atmospheric wind velocity at runtime

# NED coordinate system (North-East-Down)
float64 north    # Wind velocity component in North direction [m/s]
float64 east     # Wind velocity component in East direction [m/s]
float64 down     # Wind velocity component in Down direction [m/s] (typically 0.0)
---
bool success           # True if wind velocity was set successfully
string message         # Status message or error description
