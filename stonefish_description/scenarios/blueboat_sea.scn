<?xml version="1.0"?>
<scenario>
	<!-- Include sea world -->
	<include file="data/worlds/sea.scn"/>

	<!-- Include OptiBlueboat robot -->
	<include file="data/robots/opti_blueboat/opti_blueboat.scn">
		<arg name="vehicle_name" value="blueboat"/>
		<arg name="xyz" value="0.0 0.0 0.0"/>
		<arg name="rpy" value="0.0 0.0 0.0"/>
	</include>
</scenario>
