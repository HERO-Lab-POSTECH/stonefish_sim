# Simple box mesh for physics (2.5m x 1.5m x 1.0m) with normals
v -1.25 -0.75 -0.5
v  1.25 -0.75 -0.5
v  1.25  0.75 -0.5
v -1.25  0.75 -0.5
v -1.25 -0.75  0.5
v  1.25 -0.75  0.5
v  1.25  0.75  0.5
v -1.25  0.75  0.5

# Normals
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0

# Bottom face (normal: -Z)
f 1//1 2//1 3//1
f 1//1 3//1 4//1

# Top face (normal: +Z)
f 5//2 7//2 6//2
f 5//2 8//2 7//2

# Front face (normal: -Y)
f 1//3 5//3 6//3
f 1//3 6//3 2//3

# Back face (normal: +Y)
f 4//4 3//4 7//4
f 4//4 7//4 8//4

# Left face (normal: -X)
f 1//5 4//5 8//5
f 1//5 8//5 5//5

# Right face (normal: +X)
f 2//6 6//6 7//6
f 2//6 7//6 3//6
