<?xml version="1.0"?>
<scenario>
	<looks>
		<!-- MTL 기반 색상 -->
		<look name="very_dark_gray" rgb="0.059 0.059 0.059" roughness="0.4" metalness="0.6"/>
		<look name="gray" rgb="0.294 0.294 0.294" roughness="0.4" metalness="0.5"/>
		<look name="light_gray" rgb="0.846 0.833 0.859" roughness="0.3" metalness="0.5"/>
		<look name="duct_gray" rgb="0.098 0.098 0.098" roughness="0.4" metalness="0.6"/>
		<look name="blue" rgb="0.149 0.6 0.816" roughness="0.3" metalness="0.4"/>
		<look name="propeller" gray="0.1" roughness="0.3" metalness="0.6"/>
	</looks>

	<robot name="bluerov2" fixed="false" self_collisions="false">
		<base_link name="Vehicle" type="compound" physics="submerged">
			<!-- Ducts (6개) - Physical도 원본 사용 -->
			<external_part name="Duct1" type="model" physics="submerged" buoyant="false">
				<physical>
					<mesh filename="robots/bluerov2/meshes/bluerov2_duct_1.obj" scale="1.0"/>
					<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
				</physical>
				<material name="Neutral"/>
				<mass value="0.0001"/>
				<look name="duct_gray"/>
				<compound_transform rpy="-1.57 0.0 0.0" xyz="0.0 0.0 0.0"/>
			</external_part>

			<external_part name="Duct2" type="model" physics="submerged" buoyant="false">
