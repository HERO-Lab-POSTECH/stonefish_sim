			<internal_part name="Buoyancy_MainHull2" type="box" physics="submerged" buoyant="true">
				<dimensions xyz="0.3606 0.1153 0.1147"/>
				<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
				<material name="Neutral"/>
				<mass value="0.0001"/>
