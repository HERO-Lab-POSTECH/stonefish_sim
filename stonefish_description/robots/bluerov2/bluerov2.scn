		<!-- Sensors -->
		<sensor name="dynamics" type="odometry" rate="30.0">
			<link name="Vehicle"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<ros_publisher topic="/bluerov2/dynamics/odometry"/>
		</sensor>

		<sensor name="fls" type="fls" rate="10.0">
			<link name="Vehicle"/>
			<origin rpy="1.0472 0.0 1.5708" xyz="0.0 0.0 0.17"/>
			<specs beams="512" bins="500" horizontal_fov="130.0" vertical_fov="20.0"/>
			<settings range_min="0.5" range_max="20.0" gain="1.1"/>
			<noise multiplicative="0.01" additive="0.02"/>
			<display colormap="hot"/>
			<ros_publisher topic="/bluerov2/fls"/>
		</sensor>

		<!-- 6 Thrusters (T200) -->

		<actuator name="Thruster0" type="thruster">
			<link name="Vehicle"/>
			<origin rpy="0.0 0.0 0.7853981634" xyz="0.1355 -0.1 0.0725"/>
			<specs max_setpoint="${1000.0/60.0*2.0*pi}" inverted_setpoint="false" normalized_setpoint="true"/>
			<propeller diameter="0.114" right="true">
				<mesh filename="robots/bluerov2/meshes/bluerov2_propeller.obj" scale="0.43"/>
				<material name="Neutral" />
				<look name="propeller" />
			</propeller>
			<rotor_dynamics type="mechanical_pi">
			<rotor_inertia value="0.3"/>
				<kp value="1.0"/>
				<ki value="0.5"/>
				<ilimit value="2.0"/>
			</rotor_dynamics>
			<thrust_model type="fluid_dynamics">
				<thrust_coeff forward="0.48" reverse="0.48"/>
				<torque_coeff value="0.05"/>
			</thrust_model>
		</actuator>

		<actuator name="Thruster1" type="thruster">
