<?xml version="1.0"?>
<scenario>
	<looks>
		<look name="tank" rgb="0.9 0.9 0.9" roughness="0.9"/>
	</looks>

	<static name="Tank" type="model">
		<physical>
			<mesh filename="models/tank/meshes/cirs_tank.obj" scale="1.0"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
		</physical>
		<material name="Rock"/>
		<look name="tank"/>
		<world_transform rpy="$(arg rpy)" xyz="$(arg xyz)"/>
	</static>
</scenario>
