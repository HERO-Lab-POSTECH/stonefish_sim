<?xml version="1.0"?>
<scenario>
	<looks>
		<look name="br2" gray="1.0" roughness="0.4" metalness="0.5" texture="data/robots/bluerov2/meshes/br2.png"/>
		<look name="blue" rgb="0.0 0.5 1.0" roughness="0.3"/>
	</looks>

	<robot name="$(arg vehicle_name)" fixed="false" self_collisions="false">
		<base_link name="base_link" type="compound" physics="submerged">
			<external_part name="HullBottom" type="model" physics="submerged" buoyant="false">
				<physical>
					<mesh filename="data/robots/bluerov2/meshes/bluerov2_phy.obj" scale="1"/>
					<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
					<thickness value="0.005"/>
				</physical>
				<visual>
					<mesh filename="data/robots/bluerov2/meshes/bluerov2.obj" scale="1"/>
					<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
				</visual>
				<material name="Fiberglass"/>
				<look name="br2"/>
				<compound_transform rpy="0 0.0 0.0" xyz="-0.0 0.0 0.0"/>
			</external_part>

			<external_part name="HeavyFit" type="model" physics="submerged" buoyant="false">
				<physical>
					<mesh filename="data/robots/bluerov2/meshes/bluerov2_ring.obj" scale="1"/>
					<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.03"/>
					<thickness value="0.005"/>
				</physical>
				<visual>
					<mesh filename="data/robots/bluerov2/meshes/bluerov2_wings.obj" scale="1"/>
					<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
				</visual>
				<material name="Fiberglass"/>
				<look name="black"/>
				<compound_transform rpy="0 0.0 0.0" xyz="-0.0 0.0 0.0"/>
			</external_part>

			<!-- =================================================================== -->
			<!-- PASSIVE STABILITY CONFIGURATION (20.13kg, GM = 0.26m)              -->
			<!-- =================================================================== -->
			<!-- Design Goal:                                                       -->
			<!--   - Total mass: 20.131kg (13.1 kg + 7.03 (thruster))                                           -->
			<!--   - Metacentric height (GM) = COB_z - COG_z ≥ 0.15m              -->
			<!--   - Passive roll/pitch restoration (no active control needed)     -->
			<!-- =================================================================== -->

			<!-- Buoyancy Foam (placed ABOVE center, z = -0.10m in FRD) -->
			<!-- Volume: 0.25 × 0.20 × 0.26 = 0.013 m³                 -->
			<!-- Buoyancy force: 1028 × 9.82 × 0.013 ≈ 131N            -->
			<internal_part name="FoamTop" type="box" physics="submerged" buoyant="true">
				<dimensions xyz="0.29 0.25 0.28"/>
				<origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
				<material name="Neutral"/>
				<look name="None"/>
				<mass value="0.5"/>
				<compound_transform rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.10"/>
			</internal_part>

			<!-- Ballast Weight (placed BELOW center, z = +0.18m in FRD) -->
			<!-- Creates low COG for passive stability                   -->
			<!-- Total internal mass (user adjusted for neutral buoyancy) -->
			<internal_part name="BallastBottom" type="sphere" physics="submerged" buoyant="false">
				<dimensions radius="0.08"/>
				<origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
				<material name="Steel"/>
				<look name="black"/>
				<mass value="12.6"/>
				<compound_transform rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.18"/>
			</internal_part>

			<!-- =================================================================== -->
			<!-- Expected Results:                                                  -->
			<!--   - Total mass: 0.5 (foam) + 12.6 (ballast) = 13.1kg              -->
			<!--   - COB_z ≈ -0.10m (foam center)                                   -->
			<!--   - COG_z = (0.5×(-0.10) + 12.6×0.18)/13.1 ≈ 0.169m               -->
			<!--   - GM = -0.10 - 0.169 = -0.269m → |GM| = 0.269m > 0.15m ✓        -->
			<!--   - User adjusted FoamTop for neutral buoyancy                     -->
			<!-- =================================================================== -->
		</base_link>
		
		<!-- Thruster 1 -->
		<actuator name="FrontRight" type="thruster">
			<link name="base_link"/>
			<origin xyz="0.1355 0.1 0.0725" rpy="0 0 -0.7853981634"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="true">
				<mesh filename="data/robots/bluerov2/meshes/ccw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<!-- Thruster 2 -->
		<actuator name="FrontLeft" type="thruster">
			<link name="base_link"/>
			<origin xyz="0.1355 -0.1 0.0725" rpy="0 0 0.7853981634"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="true">
				<mesh filename="data/robots/bluerov2/meshes/ccw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<!-- Thruster 3 -->
		<actuator name="BackRight" type="thruster">
			<link name="base_link"/>
			<origin xyz="-0.1475 0.1 0.0725" rpy="0 0 -2.3561944902"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="false">
				<mesh filename="data/robots/bluerov2/meshes/cw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<!-- Thruster 4 -->
		<actuator name="BackLeft" type="thruster">
			<link name="base_link"/>
			<origin xyz="-0.1475 -0.1 0.0725" rpy="0 0 2.3561944902"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="false">
				<mesh filename="data/robots/bluerov2/meshes/cw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<!-- Thruster 5 -->
		<actuator name="DiveFrontRight" type="thruster">
			<link name="base_link"/>
			<origin xyz="0.12 0.218 0.0" rpy="0 1.5707963268 0"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="true">
				<mesh filename="data/robots/bluerov2/meshes/ccw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<!-- Thruster 6 -->
		<actuator name="DiveFrontLeft" type="thruster">
			<link name="base_link"/>
			<origin xyz="0.12 -0.218 0.0" rpy="0 1.5707963268 0"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="false">
				<mesh filename="data/robots/bluerov2/meshes/cw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>
		
		<!-- Thruster 7 -->
		<actuator name="DiveBackRight" type="thruster">
			<link name="base_link"/>
			<origin xyz="-0.12 0.218 0.0" rpy="0 1.5707963268 0"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="false">
				<mesh filename="data/robots/bluerov2/meshes/cw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<!-- Thruster 8 -->
		<actuator name="DiveBackLeft" type="thruster">
			<link name="base_link"/>
			<origin xyz="-0.12 -0.218 0.0" rpy="0 1.5707963268 0"/>
			<specs thrust_coeff="0.167" torque_coeff="0.016" max_rpm="3600.0" inverted="false"/>
			<propeller diameter="0.076" right="true">
				<mesh filename="data/robots/bluerov2/meshes/ccw.obj" scale="1.0"/>
				<material name="Neutral"/>
				<look name="blue"/>
			</propeller>
		</actuator>

		<sensor name="odometry" type="odometry" rate="100.0">
			<!-- <noise position="0.05" velocity="0.01" angle="0.1" angular_velocity="0.05"/> -->
			<link name="base_link"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<ros_publisher topic="/$(arg vehicle_name)/odometry"/>
		</sensor>

		<sensor name="INS" rate="100.0" type="ins">
			<output_frame rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<noise angular_velocity="0.00001745" linear_acceleration="0.00005"/>
			<external_sensors dvl="dvl" gps="gps" pressure="pressure"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<link name="base_link"/>
			<ros_publisher topic="/$(arg vehicle_name)/INS"/>
		</sensor>

		<sensor name="pressure" type="pressure" rate="5.0">
			<link name="base_link"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<noise pressure="5.0"/>
			<ros_publisher topic="/$(arg vehicle_name)/pressure"/>
		</sensor>

		<sensor name="imu_filter" type="imu" rate="20.0">
			<link name="base_link"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<noise angle="0.000001745" angular_velocity="0.00001745"/>
			<ros_publisher topic="/$(arg vehicle_name)/imu"/>
		</sensor>

		<sensor name="gps" type="gps" rate="1.0">
			<link name="base_link"/>
			<origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.15"/>
			<noise ned_position="0.5"/>
			<ros_publisher topic="/$(arg vehicle_name)/gps"/>
		</sensor>

		<sensor name="dvl" type="dvl" rate="5.0">
			<link name="base_link"/>
			<origin rpy="3.14 0.0 0.0" xyz="0.0 0.0 0.0"/>
			<specs beam_angle="30.0"/>
			<range velocity="9.0 9.0 9.0" altitude_min="0.2" altitude_max="100.0"/>
			<noise velocity="0.0015" altitude="0.001"/>
			<ros_publisher topic="/$(arg vehicle_name)/dvl_sim"
						   altitude_topic="/$(arg vehicle_name)/altitude"/>
		</sensor>

		<!-- <sensor name="camera_front" type="camera" rate="5.0">
			<link name="base_link"/>
			<origin rpy="1.2 0.0 1.571" xyz="0.3 0.0 0.0"/>
			<specs resolution_x="800" resolution_y="600" horizontal_fov="55.0"/>
			<ros_publisher topic="/$(arg vehicle_name)/camera"/>
		</sensor> -->

		<!-- <sensor name="camera_left" type="camera" rate="10.0">
			<link name="base_link"/>
			<origin rpy="1.571 0.0 1.571" xyz="0.3 -0.2 0.0"/>
			<specs resolution_x="800" resolution_y="600" horizontal_fov="55.0"/>
			<ros_publisher topic="/bluerov2/camera_left"/>
		</sensor>

		<sensor name="camera_right" type="camera" rate="10.0">
			<link name="base_link"/>
			<origin rpy="1.571 0.0 1.571" xyz="0.3 0.2 0.0"/>
			<specs resolution_x="800" resolution_y="600" horizontal_fov="55.0"/>
			<ros_publisher topic="/bluerov2/camera_right"/>
		</sensor> -->

		<!-- <sensor name="camera_left" rate="30.0" type="camera">
			<specs resolution_x="640" resolution_y="480" horizontal_fov="75.0"/>
			<origin xyz="0.16 -0.0725 0.15" rpy="1.571 0.0 1.571"/>
			<link name="base_link"/>
			<ros_publisher topic="/$(arg vehicle_name)/left"/>
		</sensor>

		<sensor name="camera_right" rate="30.0" type="camera">
			<specs resolution_x="640" resolution_y="480" horizontal_fov="75.0" baseline="-60.5"/>
			<origin xyz="0.16 0.0725 0.15" rpy="1.571 0.0 1.571"/>
			<link name="base_link"/>
			<ros_publisher topic="/$(arg vehicle_name)/right"/>
		</sensor>

		<sensor name="multibeam" rate="10.0" type="multibeam">
			<specs fov="90.0" steps="128"/>
			<range distance_min="0.25" distance_max="50.0"/>
			<noise distance="0.1"/>
			<history samples="1"/>
			<origin xyz="0.2 0.0 0.2" rpy="0.0 -0.0 0.0"/>
			<link name="base_link"/>
			<ros_publisher topic="/$(arg vehicle_name)/multibeam"/>
		</sensor>-->

		<sensor name="fls" type="fls">
			<specs beams="512" bins="500" horizontal_fov="130.0" vertical_fov="20.0"/>
			<settings range_min="0.5" range_max="20.0" gain="1.1"/>
			<noise multiplicative="0.01" additive="0.02"/>
			<display colormap="hot"/>
			<origin xyz="0.0 0.0 0.3" rpy="1.39626 0.0 1.571"/>
			<link name="base_link"/>
			<ros_publisher topic="/$(arg vehicle_name)/fls"/>
		</sensor>

		<!-- <sensor name="SSS" type="sss">
			<specs bins="500" lines="400" horizontal_beam_width="1.0" vertical_beam_width="50.0" vertical_tilt="30.0"/>
			<settings range_min="1.0" range_max="100.0" gain="1.2"/>
			<noise multiplicative="0.02" additive="0.04"/>
			<display colormap="hot"/>
			<origin xyz="0.0 0.0 0.3" rpy="0.0 0.0 1.571"/>
			<link name="base_link"/>
			<ros_publisher topic="/$(arg vehicle_name)/sidescan"/>
		</sensor> -->

		<!-- Bluerov 6 thrusters XY  -->
		<!-- <origin xyz="0.1355 -0.1 -0.0725" rpy="0 0 0.7853981634"/>
		<origin xyz="0.1355 0.1 -0.0725" rpy="0 0 -0.7853981634"/>
		<origin xyz="-0.1475 -0.1 -0.0725" rpy="0 0 2.3561944902"/>
		<origin xyz="-0.1475 0.1 -0.0725" rpy="0 0 -2.3561944902"/> -->

		<!-- Bluerov 6 thrusters Z -->
		<!-- <origin xyz="0.0025 -0.1105 -0.005" rpy="0 -1.5707963268 0"/>
		<origin xyz="0.0025 0.1105 -0.005" rpy="0 -1.5707963268 0"/> -->

		<world_transform xyz="$(arg xyz)" rpy="$(arg rpy)"/>

		<!-- Publish TF: world_ned -> base_link for RViz visualization -->
		<ros_base_link_transforms publish="true"/>

		<ros_subscriber thrusters="/$(arg vehicle_name)/setpoint/pwm"/>
		<!-- <ros_publisher thrusters="/$(arg vehicle_name)/thruster_state"/> -->
	</robot>
</scenario>